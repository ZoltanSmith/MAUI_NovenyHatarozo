<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MAUI_NovenyHatarozo.ViewModel"
             xmlns:model="clr-namespace:MAUI_NovenyHatarozo.Model"
             x:DataType="viewmodel:NovenyListVM"
             x:Class="MAUI_NovenyHatarozo.Pages.ListPage"
             Title="Növények">
    <CollectionView
        ItemsSource="{Binding Novenyek}"
        Margin="30,0">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="model:Noveny">
                <Grid Padding="10" RowSpacing="10" ColumnSpacing="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="30" />
                    </Grid.ColumnDefinitions>

                    <Label
                        Text="{Binding Nev}"
                        FontSize="18"
                        FontAttributes="Bold"
                        Grid.Row="0" />

                    <Label
                        Text="{Binding Vizigeny, StringFormat='Vízigény: {0}L'}"
                        FontSize="14"
                        Grid.Row="1" />

                    <CheckBox
                        IsEnabled="False"
                        IsChecked="{Binding Orokzold}"
                        Grid.Row="2" />
                </Grid>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>