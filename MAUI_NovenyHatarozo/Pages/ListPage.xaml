<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MAUI_NovenyHatarozo.ViewModel"
             xmlns:model="clr-namespace:MAUI_NovenyHatarozo.Model"
             xmlns:orientation="clr-namespace:MAUI_NovenyHatarozo.Orientation"
             x:DataType="viewmodel:NovenyListVM"
             x:Class="MAUI_NovenyHatarozo.Pages.ListPage"
             Title="Növények">
    <CollectionView
        ItemsSource="{Binding Novenyek}"
        Margin="30,0">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="model:Noveny">
                <ContentView>
                    <ContentView.MaximumWidthRequest>
                        <orientation:OnOrientation>
                            <orientation:OnOrientation.Portrait>
                                Auto
                            </orientation:OnOrientation.Portrait>
                            <orientation:OnOrientation.Landscape>
                                600
                            </orientation:OnOrientation.Landscape>
                        </orientation:OnOrientation>
                    </ContentView.MaximumWidthRequest>
                    <Border
                        Background="CadetBlue"
                        Stroke="DarkOliveGreen"
                        StrokeThickness="2">
                        <Border.StrokeShape>
                        <RoundRectangle
                            CornerRadius="30,0,0,30"/>
                        </Border.StrokeShape>
                    <Grid Padding="20,15" RowSpacing="10" ColumnSpacing="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Label
                            Text="{Binding Nev}"
                            FontSize="18"
                            FontAttributes="Bold"
                            />

                        <Label
                            Text="{Binding Vizigeny, StringFormat='Vízigény: {0}L'}"
                            FontSize="14"
                            Grid.Row="1" />

                        <CheckBox
                            IsChecked="{Binding Orokzold}"
                            Grid.Row="2">
                            <CheckBox.IsEnabled>
                                <OnPlatform
                                    x:TypeArguments="x:Boolean"
                                    Default="false">
                                    <On Platform="WinUI" Value="true" />
                                    <On Platform="MacCatalyst" Value="true" />
                                </OnPlatform>
                            </CheckBox.IsEnabled>

                        </CheckBox>

                        <Image
                            Source="{Binding Kep}"
                            WidthRequest="100"
                            HeightRequest="100"
                            Aspect="AspectFill"
                            Grid.Column="1"
                            Grid.RowSpan="3"
                            />
                    </Grid>
                </Border>
                </ContentView>
            </DataTemplate>
        </CollectionView.ItemTemplate>
    </CollectionView>

</ContentPage>