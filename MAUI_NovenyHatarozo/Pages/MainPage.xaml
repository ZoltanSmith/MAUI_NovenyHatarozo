<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:MAUI_NovenyHatarozo.ViewModel"
             x:DataType="viewmodel:MainVM"
             x:Class="MAUI_NovenyHatarozo.MainPage">

    <ScrollView>
        <VerticalStackLayout>
            <Label>
                <Label.Text>
                    <OnIdiom x:TypeArguments="x:String">
                        <OnIdiom.Phone>Phone Mode</OnIdiom.Phone>
                        <OnIdiom.Desktop>Desktop Mode</OnIdiom.Desktop>
                        <OnIdiom.Tablet>Tablet Mode</OnIdiom.Tablet>
                        <OnIdiom.Watch>Watch Mode</OnIdiom.Watch>
                        <OnIdiom.TV>TV Mode</OnIdiom.TV>
                    </OnIdiom>
                </Label.Text>
                <Label.IsVisible>
                    <OnIdiom x:TypeArguments="x:Boolean"
                                    Default="true">
                        <OnIdiom.Watch>false</OnIdiom.Watch>
                    </OnIdiom>
                </Label.IsVisible>
            </Label>
            
            <Button
                Text="Go to List Page"
                Command="{Binding GoToListViewCommand}"
                />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
