<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="MAUI_NovenyHatarozo.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:MAUI_NovenyHatarozo"
    xmlns:pages="clr-namespace:MAUI_NovenyHatarozo.Pages"
    Title="MAUI_NovenyHatarozo">

    <ShellContent
        Title="Home"
        ContentTemplate="{DataTemplate local:MainPage}"
        Route="MainPage" />

    <ShellContent
        Title="Növények"
        ContentTemplate="{DataTemplate pages:ListPage}"
        Route="ListPage" />

</Shell>
